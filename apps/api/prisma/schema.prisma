generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN

  @@map("user_role")
}

enum AuthProvider {
  LOCAL
  KAKAO
  NAVER
  GOOGLE

  @@map("auth_provider")
}

enum ContentStatus {
  ACTIVE
  BLINDED
  DELETED

  @@map("content_status")
}

enum PostCategory {
  FREE
  WORKOUT_LOG

  @@map("post_category")
}

enum ReportTargetType {
  POST
  COMMENT
  ROUTINE
  ROUTINE_COMMENT
  GYM_REVIEW

  @@map("report_target_type")
}

enum RoutineDayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY

  @@map("routine_day_of_week")
}

enum ReportStatus {
  PENDING
  RESOLVED
  REJECTED

  @@map("report_status")
}

enum CommentReactionType {
  LIKE
  DISLIKE

  @@map("comment_reaction_type")
}

enum AdSlot {
  MAIN_TOP
  MAIN_LEFT
  MAIN_RIGHT
  POST_LIST_INLINE
  GYM_DETAIL_SIDE

  @@map("ad_slot")
}

model User {
  id                Int                @id @default(autoincrement())
  email             String             @unique @db.VarChar(120)
  username          String             @unique @db.VarChar(30)
  password          String?
  nickname          String             @unique @db.VarChar(30)
  role              UserRole           @default(USER)
  passwordReset     String             @default("N") @map("password_reset") @db.Char(1)
  deleteYN          String             @default("N") @map("delete_yn") @db.Char(1)
  emailVerifiedAt   DateTime?          @map("email_verified_at")
  changePwAt        DateTime           @default(now()) @map("change_pw_at")
  deletedAt         DateTime?          @map("deleted_at")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  socialAccounts    SocialAccount[]
  posts             Post[]
  postEditHistories PostEditHistory[]  @relation("PostEditHistoryEditor")
  comments          Comment[]
  reactions         Reaction[]
  commentReactions  CommentReaction[]
  routines          Routine[]
  routineLikes      RoutineLike[]
  routineComments   RoutineComment[]
  gymReviews        GymReview[]
  reports           Report[]           @relation("ReporterReports")
  moderationLogs    ModerationAction[] @relation("AdminModerationActions")

  @@map("users")
}

model SocialAccount {
  id             Int          @id @default(autoincrement())
  provider       AuthProvider
  providerUserId String       @map("provider_user_id")
  email          String?
  userId         Int          @map("user_id")
  createdAt      DateTime     @default(now()) @map("created_at")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@map("social_accounts")
}

model Post {
  id            Int               @id @default(autoincrement())
  category      PostCategory
  title         String            @db.VarChar(180)
  content       String
  status        ContentStatus     @default(ACTIVE)
  viewCount     Int               @default(0) @map("view_count")
  authorId      Int               @map("author_id")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  author        User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments      Comment[]
  reactions     Reaction[]
  editHistories PostEditHistory[]

  @@index([category, status, createdAt])
  @@map("posts")
}

model PostEditHistory {
  id        Int      @id @default(autoincrement())
  postId    Int      @map("post_id")
  editorId  Int      @map("editor_id")
  title     String   @db.VarChar(180)
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  editor    User     @relation("PostEditHistoryEditor", fields: [editorId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@map("post_edit_histories")
}

model Comment {
  id        Int               @id @default(autoincrement())
  content   String
  status    ContentStatus     @default(ACTIVE)
  postId    Int               @map("post_id")
  authorId  Int               @map("author_id")
  parentId  Int?              @map("parent_id")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  post      Post              @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent    Comment?          @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[]         @relation("CommentReplies")
  reactions CommentReaction[]

  @@index([postId, status, createdAt])
  @@index([postId, parentId, createdAt])
  @@map("comments")
}

model CommentReaction {
  id        Int                 @id @default(autoincrement())
  commentId Int                 @map("comment_id")
  userId    Int                 @map("user_id")
  type      CommentReactionType
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")
  comment   Comment             @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId, type])
  @@map("comment_reactions")
}

model Reaction {
  id        Int      @id @default(autoincrement())
  postId    Int      @map("post_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("reactions")
}

model Routine {
  id         Int              @id @default(autoincrement())
  publicCode String           @unique @map("public_code") @db.VarChar(11)
  title      String           @db.VarChar(180)
  summary    String           @db.VarChar(240)
  content    String
  tags       String[]         @default([])
  status     ContentStatus    @default(ACTIVE)
  likeCount  Int              @default(0) @map("like_count")
  viewCount  Int              @default(0) @map("view_count")
  authorId   Int              @map("author_id")
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")
  author     User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes      RoutineLike[]
  days       RoutineDay[]
  comments   RoutineComment[]

  @@index([status, likeCount, createdAt])
  @@map("routines")
}

model RoutineDay {
  id        Int               @id @default(autoincrement())
  routineId Int               @map("routine_id")
  dayOfWeek RoutineDayOfWeek  @map("day_of_week")
  sortOrder Int               @map("sort_order")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  routine   Routine           @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exercises RoutineExercise[]

  @@unique([routineId, dayOfWeek])
  @@index([routineId, sortOrder])
  @@map("routine_days")
}

model RoutineExercise {
  id             Int           @id @default(autoincrement())
  routineDayId   Int           @map("routine_day_id")
  exerciseWikiId Int?          @map("exercise_wiki_id")
  exerciseName   String        @map("exercise_name") @db.VarChar(80)
  bodyParts      String[]      @map("body_parts")
  equipment      String?       @db.VarChar(80)
  sortOrder      Int           @map("sort_order")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  routineDay     RoutineDay    @relation(fields: [routineDayId], references: [id], onDelete: Cascade)
  exerciseWiki   ExerciseWiki? @relation(fields: [exerciseWikiId], references: [id], onDelete: SetNull)
  sets           RoutineSet[]

  @@index([routineDayId, sortOrder])
  @@index([exerciseWikiId])
  @@map("routine_exercises")
}

model RoutineSet {
  id                Int             @id @default(autoincrement())
  routineExerciseId Int             @map("routine_exercise_id")
  sortOrder         Int             @map("sort_order")
  weightKg          Int             @map("weight_kg")
  repetitions       Int?
  durationMinutes   Int?            @map("duration_minutes")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  routineExercise   RoutineExercise @relation(fields: [routineExerciseId], references: [id], onDelete: Cascade)

  @@index([routineExerciseId, sortOrder])
  @@map("routine_sets")
}

model RoutineComment {
  id        Int              @id @default(autoincrement())
  content   String
  status    ContentStatus    @default(ACTIVE)
  routineId Int              @map("routine_id")
  authorId  Int              @map("author_id")
  parentId  Int?             @map("parent_id")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  routine   Routine          @relation(fields: [routineId], references: [id], onDelete: Cascade)
  author    User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent    RoutineComment?  @relation("RoutineCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   RoutineComment[] @relation("RoutineCommentReplies")

  @@index([routineId, status, createdAt])
  @@index([routineId, parentId, createdAt])
  @@map("routine_comments")
}

model RoutineLike {
  id        Int      @id @default(autoincrement())
  routineId Int      @map("routine_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  routine   Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([routineId, userId])
  @@map("routine_likes")
}

model ExerciseWiki {
  id               Int               @id @default(autoincrement())
  slug             String            @unique
  name             String            @db.VarChar(80)
  targetMuscles    String[]          @map("target_muscles")
  equipment        String?
  difficulty       String            @db.VarChar(30)
  description      String
  howTo            String[]          @map("how_to")
  effects          String[]
  cautions         String[]
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  routineExercises RoutineExercise[]

  @@index([name])
  @@map("exercise_wikis")
}

model GymPlace {
  id                   Int          @id @default(autoincrement())
  provider             AuthProvider @default(KAKAO)
  providerPlaceId      String       @unique @map("provider_place_id")
  name                 String       @db.VarChar(160)
  categoryName         String?      @map("category_name")
  addressName          String?      @map("address_name")
  roadAddressName      String?      @map("road_address_name")
  phone                String?
  placeUrl             String?      @map("place_url")
  longitude            Float?
  latitude             Float?
  externalRating       Float?       @map("external_rating")
  externalRatingSource String?      @map("external_rating_source")
  avgRating            Float        @default(0) @map("avg_rating")
  reviewCount          Int          @default(0) @map("review_count")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")
  reviews              GymReview[]

  @@map("gym_places")
}

model GymReview {
  id        Int           @id @default(autoincrement())
  rating    Int
  content   String
  status    ContentStatus @default(ACTIVE)
  gymId     Int           @map("gym_id")
  userId    Int           @map("user_id")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  gym       GymPlace      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gymId, userId])
  @@index([gymId, status, createdAt])
  @@map("gym_reviews")
}

model Report {
  id         Int              @id @default(autoincrement())
  targetType ReportTargetType @map("target_type")
  targetId   Int              @map("target_id")
  reason     String
  status     ReportStatus     @default(PENDING)
  reporterId Int              @map("reporter_id")
  createdAt  DateTime         @default(now()) @map("created_at")
  resolvedAt DateTime?        @map("resolved_at")
  reporter   User             @relation("ReporterReports", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId, status])
  @@map("reports")
}

model ModerationAction {
  id         Int              @id @default(autoincrement())
  targetType ReportTargetType @map("target_type")
  targetId   Int              @map("target_id")
  action     String           @db.VarChar(40)
  reason     String?
  adminId    Int              @map("admin_id")
  createdAt  DateTime         @default(now()) @map("created_at")
  admin      User             @relation("AdminModerationActions", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId])
  @@map("moderation_actions")
}

model AdPlacement {
  id            Int      @id @default(autoincrement())
  slot          AdSlot   @unique
  adsenseClient String?  @map("adsense_client")
  adsenseSlot   String?  @map("adsense_slot")
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("ad_placements")
}

model DirectBanner {
  id          Int      @id @default(autoincrement())
  slot        AdSlot
  title       String   @db.VarChar(120)
  imageUrl    String   @map("image_url")
  linkUrl     String   @map("link_url")
  startsAt    DateTime @map("starts_at")
  endsAt      DateTime @map("ends_at")
  priority    Int      @default(0)
  impressions Int      @default(0)
  clicks      Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([slot, isActive, startsAt, endsAt, priority])
  @@map("direct_banners")
}
